{
  "name": "cairndex",
  "version": "0.0.0",
  "description": "Lightweight Markdown-native project memory for AI-assisted coding",
  "type": "module",
  "bin": {
    "cairndex": "./bin/cairndex"
  },
  "files": ["bin", "dist", "templates"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublish": "node scripts/copy-web.mjs"
  },
  "dependencies": {
    "@cairndex/core": "workspace:*",
    "@cairndex/server": "workspace:^",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9"
  },
  "engines": {
    "node": ">=20"
  }
}
