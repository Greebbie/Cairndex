{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cairndex",
  "version": "0.1.0",
  "identifier": "com.cairndex.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @cairndex/web dev",
    "beforeBuildCommand": "pnpm --filter @cairndex/web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cairndex",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
