{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex doctor --silent --fix --scope changed --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex --filter-path projects/cairndex/ # cairndex-managed"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex doctor --silent --auto-session --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex # cairndex-managed"
          },
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex insight propose-from-session --silent --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex # cairndex-managed"
          },
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex last-turn-summary --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex # cairndex-managed"
          },
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex sweep --silent --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex # cairndex-managed"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/bin/cairndex bootstrap --vault \"C:\\Users\\lvbab\\Documents\\CairndexVault\" --project cairndex # cairndex-managed"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cairndex": {
      "command": "node",
      "args": [
        "packages/cli/bin/cairndex",
        "mcp",
        "--vault",
        "C:\\Users\\lvbab\\Documents\\CairndexVault",
        "--project",
        "cairndex"
      ]
    }
  }
}