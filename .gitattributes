# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Explicit text files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Binary files (no normalization)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
